# ── Firebase Admin SDK 用設定 ──────────────────────────────────────
# Firebaseコンソール > プロジェクトの設定 > サービスアカウント > 新しい秘密鍵を生成 で取得したJSONから値を転記する。
# このファイルをコピーして .env.local を作り、実際の値を入れる（.env.local はコミットしないこと）。
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=xxxx@your-project-id.iam.gserviceaccount.com
# 秘密鍵は改行を含むため "..." で囲み、改行は \n とエスケープして1行で書く
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# ── アプリ設定 ──────────────────────────────────────────────────
# MVPは「1ユーザー1アラーム」前提。このPCが担当するuserIdを固定で指定する
# （iPhone側でアラームを設定したときと同じ userId / Firestoreドキュメント名と一致させる）
DEFAULT_USER_ID=user001
