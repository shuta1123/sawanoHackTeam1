{
  "name": "sawano-hack-team1-pc-app",
  "version": "0.1.0",
  "private": true,
  "description": "起床確認システム PCアプリ（Electron + Next.js）。QRコードを読み取ってアラームを解除する。",
  "main": "electron/main.js",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev": "concurrently -k \"npm:dev:next\" \"npm:dev:electron\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "firebase-admin": "^13.0.0",
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "electron": "^30.0.2",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3"
  }
}
