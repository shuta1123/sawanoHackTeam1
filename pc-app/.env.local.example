# ── Firebase 接続設定 ──────────────────────────────────────────────
# 以下のいずれかの方法で Firebase に接続してください。
# このファイルをコピーして .env.local を作り、実際の値を入れてください（.env.local はコミットしないこと）。

# ── 方法1: Firestore エミュレーター（ローカル開発・推奨） ──────────
# backend/ ディレクトリで `npm run emulator` を先に起動してから使う。
# 認証情報は不要。
#
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ── 方法2: サービスアカウント JSON を環境変数に直接埋め込む ────────
# Vercel / CI など環境変数に1行で渡せる環境で便利。
# Firebaseコンソール > プロジェクトの設定 > サービスアカウント > 新しい秘密鍵を生成 で取得した
# JSON ファイルの中身をそのまま1行に圧縮して貼り付ける。
#
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"..."}

# ── 方法3: 個別の環境変数（従来方式） ───────────────────────────
# サービスアカウント JSON から各フィールドを転記する。
#
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# 秘密鍵は改行を含むため "..." で囲み、改行は \n とエスケープして1行で書く
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# ── 方法4: サービスアカウントキーファイル（ローカル開発） ────────
# JSON ファイルをダウンロードして絶対パスを指定する。
#
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ── アプリ設定 ──────────────────────────────────────────────────
# MVPは「1ユーザー1アラーム」前提。このPCが担当するuserIdを固定で指定する。
# iPhone側でアラームを設定したときと同じ userId（Firestoreドキュメント名）と一致させること。
DEFAULT_USER_ID=user001
