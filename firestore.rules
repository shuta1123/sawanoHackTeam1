rules_version = '2';

// Cloud Firestore セキュリティルール
// 方針: 自分のデータ（userId == 認証UID）のみ読み書きできる。
//       iPhone・PC は同一ユーザーとして認証されるため、両者ともこのルールで動く。
service cloud.firestore {
  match /databases/{database}/documents {

    // 共通: 認証済みかつ本人か
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // alarms/{userId}: ドキュメントID = userId（1ユーザー1アラーム）
    match /alarms/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidAlarm(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // wakeLogs/{logId}: data.userId で所有者を判定
    match /wakeLogs/{logId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && isValidWakeLog(request.resource.data);
      // 起床ログは履歴なので更新・削除は不可
      allow update, delete: if false;
    }

    // alarm のバリデーション
    // フィールドを固定し、余計なキーや不正な曜日の書き込みを防ぐ
    //
    // updatedAt / dismissedAt は iOS SDK が Timestamp を書き、PC/backend が ISO string を書くため
    // 両方の型を受け入れる。Firestore Security Rules では timestamp 型は `is timestamp` で判定できる。
    function isValidAlarm(data) {
      return data.keys().hasOnly(['time', 'repeatDays', 'status', 'dismissedAt', 'updatedAt'])
        && data.time is string
        && data.time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')
        && data.repeatDays is list
        && data.repeatDays.hasOnly(['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'])
        && data.status in ['scheduled', 'ringing', 'dismissed', 'failed']
        && (data.dismissedAt == null || data.dismissedAt is string || data.dismissedAt is timestamp)
        && (data.updatedAt is string || data.updatedAt is timestamp);
    }

    // wakeLog のバリデーション
    // フィールドを固定し、date は月(01-12)・日(01-31)レンジまで検証する
    function isValidWakeLog(data) {
      return data.keys().hasOnly(['userId', 'date', 'wakeTime', 'success'])
        && data.userId is string
        && data.date is string
        && data.date.matches('^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$')
        && data.wakeTime is string
        && data.wakeTime.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')
        && data.success is bool;
    }
  }
}
