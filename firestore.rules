rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // デバッグ用: user001 は認証不要でアクセス可能
    function isDebugUser(userId) {
      return userId == "user001";
    }

    // alarms/{userId}/items/{alarmId}: 複数アラームのサブコレクション
    match /alarms/{userId}/items/{alarmId} {
      allow read, write: if isDebugUser(userId) || isOwner(userId);
    }

    // wakeLogs/{logId}: data.userId で所有者を判定
    match /wakeLogs/{logId} {
      allow read: if isDebugUser(resource.data.userId)
        || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if isDebugUser(request.resource.data.userId)
        || (request.auth != null
          && request.auth.uid == request.resource.data.userId);
      allow update, delete: if false;
    }
  }
}
